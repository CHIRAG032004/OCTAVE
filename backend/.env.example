PORT=3000

# Firebase Configuration
# Download your Firebase service account JSON from Firebase Console -> Project Settings -> Service Accounts
# Save it as "firebase-service-account.json" in the backend folder

# Option 1: Use file path (recommended)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Option 2: Use JSON string (alternative - useful for environment variables)
# FIREBASE_SERVICE_ACCOUNT={\"type\":\"service_account\",\"project_id\":\"your-project-id\",\"private_key_id\":\"...\",\"private_key\":\"...\",\"client_email\":\"...\",\"client_id\":\"...\",\"auth_uri\":\"...\",\"token_uri\":\"...\",\"auth_provider_x509_cert_url\":\"...\",\"client_x509_cert_url\":\"...\"}

# Third-party services
# APPWRITE_API_KEY is optional for the current session-based auth flow.
# Leave it blank unless you intentionally need admin/server Appwrite APIs.
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# Optional feature integrations. The app falls back gracefully when these are blank.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
OPENROUTER_API_KEY=
OPENCAGE_API_KEY=
